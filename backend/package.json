{
  "name": "backend",
  "version": "1.0.0",
  "description": "Simple LLM backend using @openai/agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "server": "bun run src/server.ts",
    "server:dev": "bun run --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target node",
    "start": "bun run dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["openai", "agents", "llm", "ai", "backend"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@openai/agents": "^0.3.0",
    "@types/node": "^24.10.1",
    "jsonc-parser": "^3.3.1",
    "openai": "^6.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
