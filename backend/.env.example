# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Server Configuration
PORT=3000

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://localhost:5432/aibase

# Example with authentication:
# DATABASE_URL=postgresql://user:password@localhost:5432/aibase

# Example with remote database (e.g., Neon, Supabase):
# DATABASE_URL=postgresql://user:password@host.region.provider.com:5432/database?sslmode=require
